# HTB Brain Engagement Service — Environment Variables
# Copy to .env on the pod: /workspace/tribe/.env
# All variables use the HTB_BRAIN_ prefix (read by pydantic-settings)

# HuggingFace token (for downloading TRIBE v2 cortical model)
# HF_TOKEN=hf_your_token_here

# Subcortical model (auto-detected if checkpoint exists at default path)
# HTB_BRAIN_SUBCORTICAL_CHECKPOINT_DIR=/workspace/tribe/subcortical_training/results
# HTB_BRAIN_SUBCORTICAL_MESH_META=/workspace/tribe/src/htb_brain/static/brain_mesh_combined.json

# Override defaults if needed:
# HTB_BRAIN_MODEL_REPO=facebook/tribev2
# HTB_BRAIN_MODEL_CACHE_DIR=/workspace/tribe/cache
# HTB_BRAIN_DEVICE=auto
# HTB_BRAIN_THRESHOLD_PERCENTILE=75.0
# HTB_BRAIN_PORT=8000
